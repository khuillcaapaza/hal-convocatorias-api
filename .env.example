# ── Entorno ──────────────────────────────────────────────
# true en local (muestra errores), false en producción
APP_DEBUG=false
# '/api' en producción (HestiaCP); vacío en local
APP_BASE_PATH=/api
# true = JWT solo por HTTPS (producción). false en local (HTTP)
APP_SECURE=true

# ── Autenticación JWT ────────────────────────────────────
AUTH_ENABLED=true
# Secreto para firmar tokens (mínimo 32 caracteres aleatorios)
JWT_SECRET=
# Duración del token en segundos (28800 = 8 horas)
JWT_TTL=28800

# ── CORS (orígenes del frontend, separados por coma) ─
CORS_ORIGINS=https://hospitalantoniolorena.gob.pe,https://convocatorias.hospitalantoniolorena.gob.pe

# ── Base de datos MySQL ─────────────────────────
DB_HOST=localhost
DB_NAME=haladminweb_convocatorias
DB_USER=haladminweb_convocatorias
DB_PASS=

# ── Correo SMTP (2FA: envío del código de verificación) ──
# Cuenta dedicada: noresponder@hospitalantoniolorena.gob.pe
SMTP_HOST=mail.hospitalantoniolorena.gob.pe
# 465 = SSL/TLS (SMTP_SECURE=ssl) · 587 = STARTTLS (SMTP_SECURE=tls)
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=noresponder@hospitalantoniolorena.gob.pe
# NO poner la contraseña real aquí (archivo versionado). Va en .env
SMTP_PASS=
SMTP_FROM=noresponder@hospitalantoniolorena.gob.pe
SMTP_FROM_NAME="Sistema de Convocatorias - Hospital Antonio Lorena"